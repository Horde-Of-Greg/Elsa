{
    "name": "elsa-tools",
    "version": "0.3.0",
    "description": "CI/CD tooling for Elsa",
    "license": "MIT",
    "author": "Alessian Dormal",
    "type": "module",
    "main": "main.ts",
    "scripts": {
        "tscheck": "tsc --noEmit",
        "cli": "tsx cli/index.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "lint:report": "eslint . --format json --output-file ../temp/lint/eslint_report.json",
        "lint:knip": "knip",
        "lint:duplicates": "jscpd .",
        "db:drop": "tsx scripts/db/drop.ts",
        "db:create": "tsx scripts/db/create.ts",
        "db:reset": "tsx scripts/db/reset.ts",
        "db:psql": "tsx scripts/db/psql.ts",
        "production:pull": "./scripts/production/pull.sh"
    },
    "devDependencies": {
        "@actions/core": "^2.0.1",
        "@actions/github": "^6.0.1",
        "@eslint/js": "^9.39.1",
        "@types/node": "^20.19.41",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.59.3",
        "commander": "^14.0.3",
        "dotenv": "^16.3.1",
        "eslint": "^9.39.1",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^17.23.1",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-sonarjs": "^3.0.5",
        "eslint-plugin-unused-imports": "^4.3.0",
        "globals": "^16.5.0",
        "jiti": "^2.7.0",
        "jscpd": "^4.2.4",
        "knip": "^5.73.4",
        "prettier": "^3.8.3",
        "tsx": "^4.22.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.60.1",
        "zod": "^4.4.3",
        "zod-package-json": "^2.1.0"
    }
}