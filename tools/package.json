{
    "name": "elsa-tools",
    "version": "0.3.0",
    "description": "CI/CD tooling for Elsa",
    "license": "MIT",
    "author": "Alessian Dormal",
    "type": "module",
    "main": "main.ts",
    "scripts": {
        "tscheck": "tsc --noEmit",
        "cli": "tsx cli/index.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "lint:report": "eslint . --format json --output-file ../temp/lint/eslint_report.json",
        "lint:knip": "knip",
        "lint:duplicates": "jscpd .",
        "db:drop": "tsx scripts/db/drop.ts",
        "db:create": "tsx scripts/db/create.ts",
        "db:reset": "tsx scripts/db/reset.ts",
        "db:psql": "tsx scripts/db/psql.ts",
        "production:pull": "./scripts/production/pull.sh"
    },
    "devDependencies": {
        "@actions/core": "^3.0.1",
        "@actions/github": "^9.1.1",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.2",
        "@typescript-eslint/eslint-plugin": "^8.49.0",
        "@typescript-eslint/parser": "^8.59.3",
        "commander": "^15.0.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.4.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^18.1.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-unused-imports": "^4.3.0",
        "globals": "^17.6.0",
        "jiti": "^2.6.1",
        "jscpd": "^5.0.5",
        "knip": "^6.16.1",
        "prettier": "^3.7.4",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.49.0",
        "zod": "^4.4.3",
        "zod-package-json": "^2.1.0"
    }
}